#!/bin/sh
# idk-overlay - wrapper script to launch a game with idk-overlay injected
#
# Usage:
#   idk-overlay [options] <game> [game args...]
#
# Options:
#   --socket PATH   Unix socket path (default: /tmp/idk-overlay-<pid>)
#   --no-vk         Disable Vulkan hooks
#   --no-gl         Disable OpenGL/EGL hooks
#   --lib PATH      Path to libidk-overlay.so (default: auto-detect)
#   --webview PATH  Path to idk-webview binary (default: auto-detect)
#   -h, --help      Show this help
#
# The script auto-detects the build directory relative to its own location.
# If installed system-wide, it looks in /usr/lib/ and /usr/local/lib/.

set -e

# ── Defaults ────────────────────────────────────────────────────────────
SOCKET=""
ENABLE_VK=1
ENABLE_GL=1
START_QT=0
WEBVIEW_PATH=""

# ── Find script directory (resolve symlinks) ────────────────────────────
SCRIPT="$0"
while [ -h "$SCRIPT" ]; do
    DIR=$(dirname "$SCRIPT")
    SCRIPT=$(readlink "$SCRIPT")
    case "$SCRIPT" in
        /*) ;;
        *)  SCRIPT="$DIR/$SCRIPT" ;;
    esac
done
SCRIPT_DIR=$(dirname "$SCRIPT")

# ── Find library ────────────────────────────────────────────────────────
find_lib() {
    name="$1"
    for dir in \
        "$SCRIPT_DIR/../build" \
        "$SCRIPT_DIR/../../build" \
        "$PWD/build" \
        "/usr/lib" \
        "/usr/local/lib" \
        "/usr/lib/x86_64-linux-gnu"
    do
        if [ -f "$dir/$name" ]; then
            printf '%s' "$dir/$name"
            return 0
        fi
        for f in "$dir"/${name}.*; do
            if [ -f "$f" ]; then
                printf '%s' "$f"
                return 0
            fi
        done
    done
    return 1
}

OVERLAY_LIB=$(find_lib "libidk-overlay.so" 2>/dev/null || true)

# ── Parse args ──────────────────────────────────────────────────────────
while [ $# -gt 0 ]; do
    case "$1" in
        --socket)
            SOCKET="$2"
            shift 2
            ;;
        --socket=*)
            SOCKET="${1#--socket=}"
            shift
            ;;
        --no-vk)
            ENABLE_VK=0
            shift
            ;;
        --no-gl)
            ENABLE_GL=0
            shift
            ;;
        --lib)
            OVERLAY_LIB="$2"
            shift 2
            ;;
        --lib=*)
            OVERLAY_LIB="${1#--lib=}"
            shift
            ;;
        --webview)
            WEBVIEW_PATH="$2"
            shift 2
            ;;
        --webview=*)
            WEBVIEW_PATH="${1#--webview=}"
            shift
            ;;
        -h|--help)
            cat <<'HELP'
idk-overlay - launch a game with overlay injected

Usage: idk-overlay [options] <game> [game args...]

Options:
  --socket PATH   Unix socket path (default: /tmp/idk-overlay-<pid>)
  --no-vk         Disable Vulkan hooks
  --no-gl         Disable OpenGL/EGL hooks
  --lib PATH      Path to libidk-overlay.so (default: auto-detect)
  --webview PATH  Path to idk-webview binary (default: auto-detect)
  -h, --help      Show this help
HELP
            exit 0
            ;;
        --)
            shift
            break
            ;;
        -*)
            echo "idk-overlay: unknown option: $1" >&2
            echo "Run 'idk-overlay --help' for usage." >&2
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

if [ $# -eq 0 ]; then
    echo "idk-overlay: no game specified" >&2
    echo "Run 'idk-overlay --help' for usage." >&2
    exit 1
fi

GAME="$1"
shift

# ── Verify library exists ────────────────────────────────────────────────
if [ -z "$OVERLAY_LIB" ] || [ ! -f "$OVERLAY_LIB" ]; then
    echo "idk-overlay: libidk-overlay.so not found!" >&2
    echo "  Build first: meson setup build && ninja -C build" >&2
    echo "  Or specify: --lib /path/to/libidk-overlay.so" >&2
    exit 1
fi

echo "[idk-overlay] lib:     $OVERLAY_LIB" >&2
echo "[idk-overlay] vk=$ENABLE_VK gl=$ENABLE_GL" >&2
echo "[idk-overlay] game:    $GAME $*" >&2

# ── Set socket path ──────────────────────────────────────────────────────
# If not specified, use PID-based path. The .so constructor will also
# default to /tmp/idk-overlay-<pid> if IDK_SOCKET is not set.
if [ -z "$SOCKET" ]; then
    SOCKET="/tmp/idk-overlay-$$"
fi

# ── Clean up stale socket ───────────────────────────────────────────────
rm -f "$SOCKET" 2>/dev/null || true

# ── Find webview if requested ───────────────────────────────────────────
if [ $START_QT -eq 1 ] && [ -z "$WEBVIEW_PATH" ]; then
    for dir in \
        "$SCRIPT_DIR/../build/src/cli/webview" \
        "$SCRIPT_DIR/../../build/src/cli/webview" \
        "$PWD/build/src/cli/webview" \
        "/usr/bin" \
        "/usr/local/bin"
    do
        if [ -x "$dir/idk-webview" ]; then
            WEBVIEW_PATH="$dir/idk-webview"
            break
        fi
    done
fi

# ── Launch game with LD_PRELOAD ─────────────────────────────────────────
export LD_PRELOAD="$OVERLAY_LIB"
export IDK_SOCKET="$SOCKET"
export IDK_VK="$ENABLE_VK"
export IDK_GL="$ENABLE_GL"

# Start webview in background (after short delay for socket to be created)
if [ $START_QT -eq 1 ]; then
    if [ -n "$WEBVIEW_PATH" ] && [ -x "$WEBVIEW_PATH" ]; then
        (
            sleep 2
            echo "[idk-overlay] Starting webview: $WEBVIEW_PATH" >&2
            IDK_SOCKET="$SOCKET" "$WEBVIEW_PATH" &
        ) &
    else
        echo "[idk-overlay] WARNING: idk-webview not found, skipping" >&2
    fi
fi

echo "[idk-overlay] Launching: LD_PRELOAD=$OVERLAY_LIB IDK_SOCKET=$SOCKET $GAME $*" >&2
echo "" >&2

exec "$GAME" "$@"
